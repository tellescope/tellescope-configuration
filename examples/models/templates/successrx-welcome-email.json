  "data": {
    "templates": [
      {
        "id": "670000000000000000000001",
        "title": "SuccessRX Welcome Email",
        "subject": "Welcome to SuccessRX, {{enduser.fname}} — Your Weight Loss Journey Starts Now",
        "forChannels": ["Email"],
        "type": "enduser",
        "mode": "html",
        "isMarketing": false,
        "tags": ["welcome", "onboarding", "weight-loss", "successrx"],
        "message": "Hi {{enduser.fname}},\n\nWelcome to SuccessRX! We're thrilled to have you on board.\n\nYour intake has been received and a licensed provider will review your information shortly. Here's what happens next:\n\n1. Provider Review — A licensed provider reviews your medical history and intake responses.\n2. Treatment Plan — If approved, your personalized treatment plan is created.\n3. Medication Shipped — Your medication is shipped directly to your door.\n4. Ongoing Support — Your care team is here every step of the way.\n\nWhile you wait, visit your patient portal to view your care plan, upcoming appointments, and messages from your care team.\n\nIf you have any questions, simply reply to this email or message us through your portal.\n\nHere's to a healthier you,\nThe SuccessRX Care Team\n\n{{SIGNATURE}}",
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <title>Welcome to SuccessRX</title>\n  <!--[if mso]>\n  <noscript>\n    <xml>\n      <o:OfficeDocumentSettings>\n        <o:PixelsPerInch>96</o:PixelsPerInch>\n      </o:OfficeDocumentSettings>\n    </xml>\n  </noscript>\n  <![endif]-->\n  <style>\n    @media only screen and (max-width: 600px) {\n      .container { width: 100% !important; }\n      .mobile-padding { padding: 24px 20px !important; }\n      .hero-padding { padding: 40px 20px !important; }\n      .step-table { display: block !important; }\n      .step-cell { display: block !important; width: 100% !important; padding: 0 0 16px 0 !important; }\n    }\n    .cta-btn a { color: #ffffff !important; text-decoration: none !important; font-weight: 600 !important; }\n  </style>\n</head>\n<body style=\"margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f0f4f3; -webkit-font-smoothing: antialiased;\">\n  <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\" style=\"background-color: #f0f4f3;\">\n    <tr>\n      <td style=\"padding: 40px 20px;\">\n        <!-- Main Container -->\n        <table role=\"presentation\" class=\"container\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"600\" style=\"margin: 0 auto; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06);\">\n\n          <!-- Hero Section -->\n          <tr>\n            <td class=\"hero-padding\" style=\"padding: 56px 40px 40px 40px; background: linear-gradient(135deg, #0d6b4e 0%, #14a074 50%, #1abc8c 100%); text-align: center;\">\n              <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n                <tr>\n                  <td style=\"text-align: center; padding-bottom: 24px;\">\n                    <div style=\"display: inline-block; background-color: rgba(255,255,255,0.15); border-radius: 50%; width: 72px; height: 72px; line-height: 72px; font-size: 32px;\">&#127793;</div>\n                  </td>\n                </tr>\n                <tr>\n                  <td style=\"text-align: center;\">\n                    <h1 style=\"margin: 0 0 8px 0; font-size: 28px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;\">Welcome to SuccessRX</h1>\n                    <p style=\"margin: 0; font-size: 16px; color: rgba(255,255,255,0.85); font-weight: 400;\">Your medical weight loss journey starts here</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Greeting -->\n          <tr>\n            <td class=\"mobile-padding\" style=\"padding: 40px 40px 0 40px;\">\n              <p style=\"margin: 0 0 16px 0; font-size: 18px; font-weight: 600; color: #1a2e2a;\">Hi {{enduser.fname}},</p>\n              <p style=\"margin: 0 0 16px 0; font-size: 16px; line-height: 1.6; color: #4a5855;\">Thank you for choosing SuccessRX for your weight loss journey. Your intake has been received and a <strong style=\"color: #1a2e2a;\">licensed provider</strong> will review your information shortly.</p>\n              <p style=\"margin: 0; font-size: 16px; line-height: 1.6; color: #4a5855;\">Here's what happens next:</p>\n            </td>\n          </tr>\n\n          <!-- Steps -->\n          <tr>\n            <td class=\"mobile-padding\" style=\"padding: 32px 40px 0 40px;\">\n              <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n\n                <!-- Step 1 -->\n                <tr>\n                  <td style=\"padding-bottom: 24px;\">\n                    <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n                      <tr>\n                        <td width=\"48\" valign=\"top\" style=\"padding-right: 16px;\">\n                          <div style=\"width: 48px; height: 48px; border-radius: 12px; background-color: #e8f5f0; text-align: center; line-height: 48px; font-size: 14px; font-weight: 700; color: #0d6b4e;\">01</div>\n                        </td>\n                        <td valign=\"top\">\n                          <p style=\"margin: 0 0 4px 0; font-size: 16px; font-weight: 600; color: #1a2e2a;\">Provider Review</p>\n                          <p style=\"margin: 0; font-size: 14px; line-height: 1.5; color: #6b7c78;\">A licensed provider reviews your medical history and intake responses to determine eligibility.</p>\n                        </td>\n                      </tr>\n                    </table>\n                  </td>\n                </tr>\n\n                <!-- Step 2 -->\n                <tr>\n                  <td style=\"padding-bottom: 24px;\">\n                    <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n                      <tr>\n                        <td width=\"48\" valign=\"top\" style=\"padding-right: 16px;\">\n                          <div style=\"width: 48px; height: 48px; border-radius: 12px; background-color: #e8f5f0; text-align: center; line-height: 48px; font-size: 14px; font-weight: 700; color: #0d6b4e;\">02</div>\n                        </td>\n                        <td valign=\"top\">\n                          <p style=\"margin: 0 0 4px 0; font-size: 16px; font-weight: 600; color: #1a2e2a;\">Treatment Plan</p>\n                          <p style=\"margin: 0; font-size: 14px; line-height: 1.5; color: #6b7c78;\">If approved, your personalized Semaglutide + Glycine treatment plan is created by your provider.</p>\n                        </td>\n                      </tr>\n                    </table>\n                  </td>\n                </tr>\n\n                <!-- Step 3 -->\n                <tr>\n                  <td style=\"padding-bottom: 24px;\">\n                    <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n                      <tr>\n                        <td width=\"48\" valign=\"top\" style=\"padding-right: 16px;\">\n                          <div style=\"width: 48px; height: 48px; border-radius: 12px; background-color: #e8f5f0; text-align: center; line-height: 48px; font-size: 14px; font-weight: 700; color: #0d6b4e;\">03</div>\n                        </td>\n                        <td valign=\"top\">\n                          <p style=\"margin: 0 0 4px 0; font-size: 16px; font-weight: 600; color: #1a2e2a;\">Medication Shipped</p>\n                          <p style=\"margin: 0; font-size: 14px; line-height: 1.5; color: #6b7c78;\">Your medication is shipped directly to your door with everything you need to get started.</p>\n                        </td>\n                      </tr>\n                    </table>\n                  </td>\n                </tr>\n\n                <!-- Step 4 -->\n                <tr>\n                  <td style=\"padding-bottom: 8px;\">\n                    <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n                      <tr>\n                        <td width=\"48\" valign=\"top\" style=\"padding-right: 16px;\">\n                          <div style=\"width: 48px; height: 48px; border-radius: 12px; background-color: #e8f5f0; text-align: center; line-height: 48px; font-size: 14px; font-weight: 700; color: #0d6b4e;\">04</div>\n                        </td>\n                        <td valign=\"top\">\n                          <p style=\"margin: 0 0 4px 0; font-size: 16px; font-weight: 600; color: #1a2e2a;\">Ongoing Support</p>\n                          <p style=\"margin: 0; font-size: 14px; line-height: 1.5; color: #6b7c78;\">Your care team is with you every step of the way — check-ins, dosage adjustments, and guidance.</p>\n                        </td>\n                      </tr>\n                    </table>\n                  </td>\n                </tr>\n\n              </table>\n            </td>\n          </tr>\n\n          <!-- CTA -->\n          <tr>\n            <td class=\"mobile-padding\" style=\"padding: 32px 40px;\">\n              <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\" style=\"background-color: #f7faf9; border-radius: 12px;\">\n                <tr>\n                  <td style=\"padding: 28px 24px; text-align: center;\">\n                    <p style=\"margin: 0 0 16px 0; font-size: 15px; line-height: 1.5; color: #4a5855;\">While you wait, visit your patient portal to view your care plan, messages, and more.</p>\n                    <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"margin: 0 auto;\">\n                      <tr>\n                        <td class=\"cta-btn\" style=\"border-radius: 8px; background-color: #0d6b4e; padding: 14px 32px; font-size: 15px; font-weight: 600; text-align: center; letter-spacing: 0.3px;\">\n                          {{portal.link.care-plan:Visit Your Portal}}\n                        </td>\n                      </tr>\n                    </table>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Divider -->\n          <tr>\n            <td style=\"padding: 0 40px;\">\n              <div style=\"height: 1px; background-color: #e8edeb;\"></div>\n            </td>\n          </tr>\n\n          <!-- Sign-off -->\n          <tr>\n            <td class=\"mobile-padding\" style=\"padding: 32px 40px;\">\n              <p style=\"margin: 0 0 4px 0; font-size: 16px; line-height: 1.6; color: #4a5855;\">Here's to a healthier you,</p>\n              <p style=\"margin: 0 0 20px 0; font-size: 16px; font-weight: 600; color: #1a2e2a;\">The SuccessRX Care Team</p>\n              <div style=\"font-size: 14px; line-height: 1.5; color: #6b7c78;\">{{SIGNATURE.EMAIL}}</div>\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"padding: 24px 40px 32px 40px; background-color: #f7faf9; border-top: 1px solid #e8edeb;\">\n              <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n                <tr>\n                  <td style=\"text-align: center;\">\n                    <p style=\"margin: 0 0 8px 0; font-size: 13px; color: #8a9895;\">Questions? Simply reply to this email or message us through your portal.</p>\n                    <p style=\"margin: 0; font-size: 12px; color: #aab5b2;\">This email was sent to {{enduser.email}} because you enrolled in the SuccessRX Medical Weight Loss Program.</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>"
      }
    ]
  }
}